# NextPitch environment. Copy to .env for local dev (backend/ + scripts/).
# Production runs on Supabase; the values that live in the DB (app_secrets)
# rather than env are noted at the bottom.

# ── Supabase connection (scripts/train_models.py, backend local stack) ──────
# Project API URL and a key. Reads (training RPCs, public data) work with the
# anon/publishable key; writes to model_params need the service_role key.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_KEY=<service_role-or-anon-key>

# Frontend build (scripts/build_frontend.sh). If unset it defaults to this
# project's functions URL; set empty to force sample-data demo mode.
SUPABASE_FUNCTIONS_URL=https://<ref>.supabase.co/functions/v1

# ── FastAPI local-dev backend (backend/config.py) ──────────────────────────
# Optional API key + per-IP rate limit for the local FastAPI API.
API_KEY=
RATE_LIMIT_PER_MINUTE=120

# Poll / refresh cadences (seconds) — override to tune without code changes.
POLL_INTERVAL_SECONDS=8
STATS_REFRESH_SECONDS=3600
ROLLING_REFRESH_SECONDS=1800
FALLBACK_TTL_SECONDS=300
ROLLING_TTL_SECONDS=600
MATCHUP_TTL_SECONDS=1800
GAME_CTX_TTL_SECONDS=900
GAME_LOG_TTL_SECONDS=120

# ── Odds provider (optional) ───────────────────────────────────────────────
# The Odds API key. In production this lives in app_secrets.the_odds_api_key
# (see below), not env — the odds-ingest function reads it there. Kept here for
# local reference only.
THE_ODDS_API_KEY=

# ── Values stored in Supabase app_secrets (NOT env) ────────────────────────
# Set via SQL / MCP execute_sql, never exposed to the API (RLS, no policy):
#   cron_secret          shared secret pg_cron sends as x-cron-secret
#   functions_base_url    https://<ref>.supabase.co/functions/v1
#   allowed_origins       comma-separated CORS allowlist for the api function
#                         (e.g. https://nextpitch.vercel.app); "*" until set
#   season_start          backfill window start (YYYY-MM-DD); defaults to
#                         <year>-03-15 when absent
#   the_odds_api_key      activates the The Odds API provider in odds-ingest
#   SPORTSBOOK_AFF_*      per-book affiliate params, if/when monetized
